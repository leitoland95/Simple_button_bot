import os
import asyncio
import threading
import time
import requests
from fastapi import FastAPI, Request
from fastapi.responses import FileResponse
from fastapi.staticfiles import StaticFiles
from fastapi.middleware.cors import CORSMiddleware

app = FastAPI()

# Permitir CORS
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_methods=["*"],
    allow_headers=["*"],
)

# Montar carpeta "frontend" para servir archivos estáticos
app.mount("/frontend", StaticFiles(directory="frontend"), name="frontend")

logs = []

@app.get("/")
def serve_index():
    # Devuelve el frontend principal
    return FileResponse(os.path.join("frontend", "index.html"))

@app.post("/verify")
async def verify(request: Request):
    data = await request.json()
    bot_name = data.get("bot_name", "desconocido")
    logs.append(f"Bot recibido: {bot_name}")
    return {"message": "Recibido"}

@app.get("/logs")
async def get_logs():
    return logs

# -------------------------------
# Self-ping para evitar inactividad en Render
# -------------------------------
def keep_alive():
    url = "https://full-stack-z81t.onrender.com/"  # Render expone esta variable con tu URL pública
    if not url:
        return
    while True:
        try:
            requests.get(url)
        except Exception as e:
            print("Error en self-ping:", e)
        time.sleep(60)  # cada 10 minutos

@app.on_event("startup")
async def startup_event():
    # Lanzar el self-ping en un hilo aparte
    threading.Thread(target=keep_alive, daemon=True).start()